# Node.js dependencies - can be reinstalled
node_modules/

# Python virtual environment - can be recreated
venv/

# Build output directories - generated files
.next/
dist/
build/

# Log files - not part of the project's core logic
*.log

# Environment variables - sensitive and should not be in context
.env
.env.local
.env.development.local
.env.production.local

# IDE and OS generated files - not part of the project's code
.vscode/
.idea/
.DS_Store
Thumbs.db

# Test coverage reports - generated data
coverage/

# Other common temporary or generated files
tmp/
*.tmp
*.bak

# Specific to NestJS/TypeScript compilation - generated files
ttsconfig.tsbuildinfo

# Specific to Next.js caching - temporary cache files
.next/cache/

